# Copier ce fichier en .env et remplir les valeurs réelles
# Ne JAMAIS commiter .env dans git

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=remplacer-par-une-cle-aleatoire-longue
DEBUG=False
ALLOWED_HOSTS=ever.ifop.com

# ── SQL Server ────────────────────────────────────────────────────────────────
# En production Docker : utiliser l'IP (pas le hostname) car le DNS interne
# IFOP n'est pas résolu dans les conteneurs.
# Format instance nommée : IP\NomInstance
# Port explicite — le SQL Server Browser (UDP 1434) n'est pas accessible depuis Docker
DB_HOST=10.10.1.27,2067
DB_NAME=EVER_2026
DB_USER=compte_sql_ever        # compte SQL dédié à créer par Philippe
DB_PASSWORD=mot_de_passe_sql

# ── Mots de passe applicatifs ─────────────────────────────────────────────────
FIRST_LOGIN_PASSWORD=Ever@2026
ADMIN_PASSWORD=mot_de_passe_admin_affectation

# ── Sessions (chemin dans le conteneur, monté en volume Docker) ───────────────
SESSION_FILE_PATH=/app/sessions
